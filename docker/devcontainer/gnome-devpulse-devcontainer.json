{
  "name": "gnome-devpulse",
  "dockerComposeFile": "/home/nick/NickManage/docker/compose/dev-gnome-devpulse.yaml",
  "service": "devcontainer",
  "workspaceFolder": "/workspace/gnome-shell/extensions/devpulse@nickmanage.local",

  "mounts": [
    {
      "source": "${localEnv:HOME}/.local/share/gnome-shell/extensions/devpulse@nickmanage.local",
      "target": "/ext-deploy",
      "type": "bind"
    }
  ],

  "containerEnv": {
    "EXTENSION_UUID": "devpulse@nickmanage.local",
    "GNOME_EXTENSIONS_DIR": "/ext-deploy"
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {
      "installZsh": true,
      "configureZshOhMyZsh": true,
      "upgradePackages": true,
      "username": "developer"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "postCreateCommand": "npm install && (ls schemas && glib-compile-schemas schemas || true)",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "timonwong.shellcheck"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "eslint.enable": true,
        "files.eol": "\n",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "remoteUser": "developer"
}
