{
  "name": "LifeScript",
  "dockerComposeFile": [
    "/home/nick/NickManage/docker/compose/dev-LifeScript.yaml"
  ],
  "service": "dev-LifeScript",
  "workspaceFolder": "/workspaces/LifeScript",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "installHelm": true,
      "installMinikube": false
    }
  },
  "remoteEnv": {
    "LANG_RUNTIME": "node",
    "LANG_VERSION": "20",
    "PROJECT_NAME": "LifeScript",
    "LOG_DIR": "/logs",
    "GITEA_URL": "${localEnv:GITEA_URL}",
    "GITEA_USER": "${localEnv:GITEA_USER}",
    "GITEA_TOKEN": "${localEnv:GITEA_TOKEN}",
    "REDIS_HOST": "share-redis",
    "POSTGRES_HOST": "share-postgres",
    "EMBEDDING_HOST": "share-embedding",
    "LLM_HOST": "share-embedding",
    "GIT_USER_NAME": "${localEnv:GITEA_USER_NAME}",
    "GIT_USER_EMAIL": "${localEnv:GITEA_USER_EMAIL}"
  },
  "postCreateCommand": "echo '正在准备工作空间...' && mkdir -p ${containerWorkspaceFolder} && git config --global --add safe.directory ${containerWorkspaceFolder} && git config --global user.name \\\"${GIT_USER_NAME}\\\" && git config --global user.email \\\"${GIT_USER_EMAIL}\\\" && cd ${containerWorkspaceFolder} && [ -d .git ] || (git init . && git remote add origin http://token:${GITEA_TOKEN}@ops-gitea:3000/nick/${PROJECT_NAME}.git && git fetch origin && git checkout -f master || true)",
  "postStartCommand": "echo '检查通讯状态...' && (curl -sSf http://ops-gitea:3000 > /dev/null && echo 'Gitea: OK' || echo 'Gitea: FAIL')",
  "mounts": [
    "source=/home/nick/NickManage/volumes/dev/LifeScript/vscode-server,target=/home/vscode/.vscode-server,type=bind",
    "source=/home/nick/.antigravity,target=/home/vscode/.antigravity,type=bind",
    "source=/home/nick/.gemini,target=/home/vscode/.gemini,type=bind"
    ,"source=${MNG_DIR}/volumes/share/git/gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly=true"
    ,"source=${MNG_DIR}/volumes/share/git/.git-credentials,target=/home/vscode/.git-credentials,type=bind,readonly=true"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "cweijan.vscode-postgresql-client2",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "humao.rest-client",
        "rangav.vscode-thunder-client",
        "continue.continue",
        "ms-python.python",
        "ms-toolsai.jupyter",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-vscode.js-debug"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "files.eol": "\n",
        "terminal.integrated.defaultProfile.linux": "bash",
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        }
      }
    }
  }
}
