{
  "name": "JavaTeachingSolution",
  "dockerComposeFile": [
    "/home/nick/NickManage/docker/compose/dev-JavaTeachingSolution.yaml"
  ],
  "service": "dev-JavaTeachingSolution",
  "workspaceFolder": "/workspaces/JavaTeachingSolution",
  "remoteUser": "vscode",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {
      "installZsh": true,
      "configureZshOhMyZsh": true,
      "upgradePackages": true,
      "username": "vscode",
      "userUid": "1000",
      "userGid": "1000"
    },
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "installHelm": true,
      "installMinikube": false
    }
  },
  "remoteEnv": {
    "LANG_RUNTIME": "java",
    "LANG_VERSION": "17",
    "PROJECT_NAME": "JavaTeachingSolution",
    "LOG_DIR": "/logs",
    "GITEA_URL": "${localEnv:GITEA_URL}",
    "GITEA_USER": "${localEnv:GITEA_USER}",
    "GITEA_TOKEN": "${localEnv:GITEA_TOKEN}",
    "REDIS_HOST": "share-redis",
    "POSTGRES_HOST": "share-postgres",
    "EMBEDDING_HOST": "share-embedding",
    "LLM_HOST": "share-embedding",
    "GIT_USER_NAME": "${localEnv:GITEA_USER_NAME}",
    "GIT_USER_EMAIL": "${localEnv:GITEA_USER_EMAIL}"
  },
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode && sudo apt-get update && sudo apt-get install -y curl wget git ca-certificates sudo libatomic1 libgbm1 libasound2t64 libnss3 libx11-xcb1 libxcb-dri3-0 lsb-release libsecret-1-0 libgtk-3-0 libxss1 libxkbfile1 docker.io docker-compose-v2 && echo '正在准备工作空间...' && mkdir -p ${containerWorkspaceFolder} && git config --global --add safe.directory ${containerWorkspaceFolder} && git config --global user.name \"${GIT_USER_NAME}\" && git config --global user.email \"${GIT_USER_EMAIL}\" && cd ${containerWorkspaceFolder} && [ -d .git ] || (git init . && git remote add origin http://token:${GITEA_TOKEN}@ops-gitea:3000/nick/${PROJECT_NAME}.git && git fetch origin && git checkout -f master || true)",
  "postStartCommand": "echo '检查通讯状态...' && (curl -sSf http://ops-gitea:3000 > /dev/null && echo 'Gitea: OK' || echo 'Gitea: FAIL')",
  "mounts": [
    "source=${MNG_HOME}/volumes/share/git/gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly=true",
    "source=${MNG_HOME}/volumes/share/git/.git-credentials,target=/home/vscode/.git-credentials,type=bind,readonly=true"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "cweijan.vscode-postgresql-client2",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "humao.rest-client",
        "rangav.vscode-thunder-client",
        "continue.continue",
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.pylint",
        "ms-python.black-formatter",
        "ms-python.debugpy",
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven",
        "vscjava.vscode-java-debug"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "files.eol": "\n",
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "java.jdt.ls.java.home": "/usr/local/sdkman/candidates/java/current"
      }
    }
  }
}
